rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all (First)
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helper Primitives
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // ===============================================================
    // Domain Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (!('monthlyBudget' in data) || data.monthlyBudget is number) &&
             (!('currency' in data) || data.currency is string && data.currency.size() <= 10);
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['userId', 'dream', 'concreteGoal', 'category', 'cost', 'priority', 'deadline', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.dream is string && data.dream.size() > 0 && data.dream.size() <= 500 &&
             data.concreteGoal is string && data.concreteGoal.size() > 0 && data.concreteGoal.size() <= 500 &&
             data.category in ['short-term', 'medium-term', 'long-term'] &&
             data.cost is number && data.cost >= 0 &&
             data.priority is int && data.priority >= 0 &&
             data.deadline is timestamp &&
             data.createdAt is timestamp;
    }

    function isValidSaving(data) {
      return data.keys().hasAll(['userId', 'amount', 'date']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 0 &&
             data.date is timestamp &&
             (!('goalId' in data) || (data.goalId == null || (isValidId(data.goalId))));
    }

    function isValidSpending(data) {
      return data.keys().hasAll(['userId', 'amount', 'category', 'isNeed', 'date']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.isNeed is bool &&
             data.date is timestamp &&
             (!('description' in data) || data.description is string && data.description.size() <= 1000);
    }

    // ===============================================================
    // Collection Match Blocks
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'monthlyBudget', 'currency'])
      );
    }

    match /goals/{goalId} {
      allow get: if isOwner(existing().userId) && isValidId(goalId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidGoal(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidGoal(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['dream', 'concreteGoal', 'category', 'cost', 'priority', 'deadline'])
      );
      allow delete: if isOwner(existing().userId);
    }

    match /savings/{savingId} {
      allow get: if isOwner(existing().userId) && isValidId(savingId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidSaving(incoming()) && (
        !('goalId' in incoming()) || incoming().goalId == null || exists(/databases/$(database)/documents/goals/$(incoming().goalId))
      );
      allow update: if isVerified() && isOwner(existing().userId) && isValidSaving(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'date', 'goalId']) &&
        (!('goalId' in incoming()) || incoming().goalId == null || exists(/databases/$(database)/documents/goals/$(incoming().goalId)))
      );
      allow delete: if isOwner(existing().userId);
    }

    match /spending/{spendingId} {
      allow get: if isOwner(existing().userId) && isValidId(spendingId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidSpending(incoming());
      allow update: if isVerified() && isOwner(existing().userId) && isValidSpending(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'isNeed', 'date', 'description'])
      );
      allow delete: if isOwner(existing().userId);
    }

    match /quizResults/{resultId} {
      allow get: if isOwner(existing().userId) && isValidId(resultId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && incoming().userId == request.auth.uid;
    }
  }
}
